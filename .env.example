# ThaleOS Quantum Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ─── LLM Integrations ───────────────────────────────────────────────────────

# Anthropic Claude (get key at: https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT (get key at: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Perplexity AI (get key at: https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-...

# xAI Grok (get key at: https://console.x.ai)
GROK_API_KEY=xai-...

# GitHub Copilot / GitHub Models (Personal Access Token with models:read scope)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Qwant Search — no API key required for basic use
# QWANT_API_KEY=  (optional — for higher rate limits)

# GPT4All — local only, no key required
# Set the directory where .gguf model files are stored (optional)
# GPT4ALL_MODEL_PATH=/path/to/models

# ─── ThaleOS Backend ─────────────────────────────────────────────────────────

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED for production — change this!
JWT_SECRET_KEY=thaleos-dev-secret-change-in-production-32chars

# Backend API port (default: 8099)
THALEOS_PORT=8099

# Frontend API endpoint (used by Vite build)
VITE_API_URL=http://localhost:8099
VITE_WS_URL=ws://localhost:8099

# ─── GPT4All Listener ────────────────────────────────────────────────────────

# Directory where external bots drop .json files for ThaleOS to process
THALEOS_INBOX=/tmp/thaleos_inbox

# ─── Google Calendar Integration ─────────────────────────────────────────────

# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Add http://localhost:8099/api/calendar/callback as an authorised redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8099/api/calendar/callback

# ─── Optional Integrations ───────────────────────────────────────────────────

# Database URL (leave empty to use in-memory storage)
# DATABASE_URL=postgresql://user:password@localhost/thaleos

# ThaleOS Terminal CLI target API
THALEOS_API=http://localhost:8099
